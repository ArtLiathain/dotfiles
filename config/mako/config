# NOTE: This file is managed by Wallust. Do not edit manually. 
# Font and dimensions
font=JetBrains Mono 10
width=300
height=100
margin=10
padding=15
border-size=2
border-radius=8
icons=1
max-icon-size=48
max-visible=5
layer=overlay
anchor=top-right

default-timeout=5000
# Default notification style - using background as the base
background-color=#0F0000
text-color=#E9FCFB
border-color=#7E7872
progress-color=over #96AAA9

# Grouped notifications
[grouped]
background-color=#5E7A75
border-color=#7E7872
format=<b>%s</b>\n%b (%g)


